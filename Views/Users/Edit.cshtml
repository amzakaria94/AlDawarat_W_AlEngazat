@model AlDawarat_W_AlEngazat.Models.Entities.User

@{
	ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>User</h4>
<hr />
<div class="row">
	<div class="col-md-4">
		<form asp-action="Edit">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<input type="hidden" asp-for="ID" />
			<div class="form-group">
				<label asp-for="Name" class="control-label"></label>
				<input asp-for="Name" class="form-control" />
				<span asp-validation-for="Name" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="NationalID" class="control-label"></label>
				<input asp-for="NationalID" class="form-control" />
				<span asp-validation-for="NationalID" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="Category" class="control-label"></label>
				<select asp-for="Category" class="form-control">
					<option value="10">10</option>
					<option value="20">20</option>
					<option value="30">30</option>
				</select>
				<span asp-validation-for="Category" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="Department" class="control-label"></label>
				<input asp-for="Department" class="form-control" />
				<span asp-validation-for="Department" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="Position" class="control-label"></label>
				<input asp-for="Position" class="form-control" />
				<span asp-validation-for="Position" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="Certificate" class="control-label"></label>
				<select asp-for="Certificate" class="form-control">
					<option value="تاسيسيه">تاسيسيه</option>
					<option value="متقدمه">متقدمه</option>
					<option value="بدون مؤهل">بدون مؤهل</option>
				</select>
				<span asp-validation-for="Certificate" class="text-danger"></span>
			</div>

			<!-- Achievements Section -->
			<h4>Achievements</h4>
			<div id="achievements-container">
				@for (int i = 0; i < Model.Achievements.Count; i++)
				{
					<div class="achievement-item">
						<input type="hidden" asp-for="@Model.Achievements[i].ID" />
						<input type="hidden" asp-for="@Model.Achievements[i].UserID" /> <!-- Add this line -->
						<div class="form-group">
							<label asp-for="@Model.Achievements[i].Title" class="control-label"></label>
							<input asp-for="@Model.Achievements[i].Title" class="form-control" />
							<span asp-validation-for="@Model.Achievements[i].Title" class="text-danger"></span>
						</div>
						<div class="form-group">
							<label asp-for="@Model.Achievements[i].StartDate" class="control-label"></label>
							<input type="date" asp-for="@Model.Achievements[i].StartDate" class="form-control" />
							<span asp-validation-for="@Model.Achievements[i].StartDate" class="text-danger"></span>
						</div>
						<div class="form-group">
							<label asp-for="@Model.Achievements[i].EndDate" class="control-label"></label>
							<input type="date" asp-for="@Model.Achievements[i].EndDate" class="form-control" />
							<span asp-validation-for="@Model.Achievements[i].EndDate" class="text-danger"></span>
						</div>
					</div>
				}
			</div>

			<div class="form-group">
				<input type="submit" value="Save" class="btn btn-primary" />
			</div>
		</form>
	</div>
</div>

<div>
	<a asp-action="List">Back to List</a>
</div>

@section Scripts {
	@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}